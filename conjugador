					"tribuir":-1, "contribuir":3, "distribuir":3, "retribuir":2, "atribuir":1,"redistribuir":5,
					"air":-1, "sair":1, "cair":1, "trair":2, "distrair":5, "contrair":5,
					"struir":-1, "construir":3, "destruir":2,
					"uzir":-1, "traduzir":4, "reduzir":3, "reluzir":3,
					"iar":-1, "ansiar":3, "mediar":3, "remediar":5, "incendiar":6,"odiar":2,
		})

