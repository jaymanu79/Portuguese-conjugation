## Tools

# A dictionary which accepts "all" key as wildcard
from collections import UserDict
class AllDict(UserDict):
	def all(self,allValue):
		super().__setitem__("all",allValue)
	def __contains__(self,item):
		if(super().__contains__("all")):
			return True
		else:
			return super().__contains__(item)

	def __getitem__(self,key):
		if(self.__contains__("all")):
			return self.data["all"]
		else:
			return self.data[key]
def allDict(allValue):
	return AllDict({"all":allValue})


## Main

def main():
	# Gather all available tempos
	allTempos={}
	letra='A'
	for tempo in Tempo.__subclasses__():
		allTempos[letra]=tempo()
		letra=chr(ord(letra)+1)

	# Parse arguments if present
	verbos=[]
	verbosInteractive=True
	if len(sys.argv)>1:
		selec=sys.argv[1]
		verbos=sys.argv[2:]
		if verbos:
			verbosInteractive=False
			
	else:
		# if not, list tempos and ask for selection
		print("\nTempos:\n"+"-"*30)
		for letra,tempo in allTempos.items():
			print(letra+" - "+tempo.nome)
		print("-"*30)
		selec=input("Seleção (ex. ABC) - '*' para tudo - enter to quit ? ")

	# make selection
	if(selec == "*"):
		tempos=allTempos.values()
	else:
		tempos=[allTempos[s] for s in selec.upper() if s in allTempos.keys()]
		if not tempos:
			exit()

	# main loop input verbs
	while True:
		if verbosInteractive:
			print ("_" * 30)
			verbo=input("Verbo (enter to quit) ? ")
		else:
			verbo=verbos.pop(0) if len(verbos)>0 else ""
		if(verbo == ""):
			print ("_" * 30)
			break
		for tempo in tempos:	
			print ("_" * 30)
			tempo.verbo=verbo
			print ("")
			print (tempo.info())
			tempo.conjugTudo()

if __name__ == "__main__":
	main()


