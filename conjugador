## Tempos

class Tempo():
	@property
	@abstractmethod
	def nome(self):
		pass

	def __init__(self):
		self.irreg=False

	@property
	def verbo(self):
		return self._pverbo+self._verbo
	@verbo.setter
	def verbo(self,value):
		if (value in self.verbosPrefixo):
			if (self.verbosPrefixo[value]==-1):
				raise Exception("Este verbo nao existe sin prefixo")
			self._pverbo=value[:self.verbosPrefixo[value]:]
			self._verbo=value[self.verbosPrefixo[value]:]
		else:
			self._pverbo=""
			self._verbo=value

	def grupo(self):
		if (self._verbo.endswith("ar") or self._verbo.endswith("or")):
			return "1"
		elif (self._verbo.endswith("er")):
			return "2"
		elif (self._verbo.endswith("ir")):
			return "3"
		else:
			raise Exception("impossivel ter grupo para verbo "+self._verbo)

	@property
	def pessoas(self):
		return {"eu":"eu","tu":"tu","ele":"ele","nos":"nós","eles":"eles"}

	@property
	def prefixo(self):
		return ""	

	@property
	def suffixo(self):
		return ""

	def info(self):
		return (self.verbo + " (G" + self.grupo() + ") - " + self.nome)

	@property
	@abstractmethod
	def term_regular(self):
		pass	

	@property
	@abstractmethod
	def radical_irreg(self):
		return {}	

	def radical(self,pessoa):
		if (self._verbo in self.radical_irreg and pessoa in self.radical_irreg[self._verbo]):
			self.irreg=True	
			return self.radical_irreg[self._verbo][pessoa]
		else:
			if (self._verbo[-2:] in ["ar","er","ir","or"]):
				return self._verbo[:-2]
			else:
				raise Exception("impossivel ter radical para verbo " +self._verbo)

	@property
	@abstractmethod
	def verbo_irreg(self):
		return {}

	def terminacao(self,pessoa):
		return self.term_regular[self.grupo()][pessoa]

	def conjug(self,pessoa):
		self.irreg=False
		if (self._verbo in self.verbo_irreg and pessoa in self.verbo_irreg[self._verbo]):
			self.irreg=True
			return (self._pverbo + self.verbo_irreg[self._verbo][pessoa])
		else:
			radical=self._pverbo + self.radical(pessoa)
			terminacao=self.terminacao(pessoa)
			radical=self.reparaSonido(radical,terminacao)	
			return (radical + terminacao)

	def conjugTudo(self,option=""):
		if (option == ""):
			for pessoa in self.pessoas.keys():
				print (self.prefixo+self.pessoas[pessoa] + (" " if self.pessoas[pessoa]!="" else "") + self.conjug(pessoa)+("*" if self.irreg else "")+self.suffixo)
		elif (option == "ter"):
			for pessoa in self.pessoas.keys():
				print (self.prefixo+self.pessoas[pessoa] + " " + self.conjugInfinitivo(pessoa,"ter","de")+self.suffixo)
		elif (option == "ir"):
			for pessoa in self.pessoas.keys():
				print (self.pessoas[pessoa] + " " + self.conjugInfinitivo(pessoa,"ir","")+self.suffixo)

	def conjugInfinitivo(self,pessoa,verbo2,sep):
		self.irreg=False
		infinitivo=self.verbo
		self.verbo=verbo2
		result=self.conjug(pessoa) + ("*" if self.irreg else "") + " " + (sep + " " if sep!="" else "") + infinitivo
		self.verbo=infinitivo
		return result

	# Sometimes we need to change g to gu, c to ç, q tu su etc.
	# in order to maintain correct pronunciation with all terminations
	def reparaSonido(self,radical,terminacao):
		patternInf="(.*)(g|gu|j|c|qu|ç)([aeiou])r$"
		patternConj="(.*)(g|gu|j|c|qu|ç)([aeiou])$"
		match=re.search(patternInf,self.verbo)
		if match:
			baseInf=match.group(1)
			consonInf=match.group(2)
			vogalInf=match.group(3)
			consonConj=radical[-1]
			vogalConj=terminacao[0]
			if consonInf=="g" and vogalInf in "aou" and vogalConj in "ei":
				radical="*"+baseInf+"gu"
			elif consonInf=="g" and vogalInf in "ei" and vogalConj in "aou":
				radical="*"+baseInf+"j"	
			elif consonInf=="c" and vogalInf in "aou" and vogalConj in "ei":
				radical="*"+baseInf+"qu"	
			elif consonInf=="c" and vogalInf in "ei" and vogalConj in "aou":
				radical="*"+baseInf+"ç"	
		return radical

	# verbos that consist of a prefix + a known verbo
	# define the length in characters constituting this prefix
	# value of -1 means that the verb doesn't exist without any prefix
	@property
	def verbosPrefixo(self):
		return( {	"sorrir":3,
					"opor":1, "dispor":3, "apor":1, "antepor":4, "apor":1, "antepor":4, "compor":3, "contrapor":6, "depor":2, "dispor":3, "expor":2, "justapor":5, "propor":3,
